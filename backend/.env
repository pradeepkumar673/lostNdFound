# ── Flask ──────────────────────────────────
SECRET_KEY=campus-lost-found-super-secret-change-in-prod
JWT_SECRET_KEY=jwt-campus-secret-change-in-prod
DEBUG=True

# ── MongoDB ────────────────────────────────
MONGO_URI=mongodb://localhost:27017/campuslostfound

# ── Cloudinary ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google Gemini ──────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Redis / Celery ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Models ──────────────────────────────
MODEL_PATH=models/categorization_model.h5
CLASSES_PATH=models/classes.txt
